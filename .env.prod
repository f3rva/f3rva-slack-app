# ==============================================================================
# F3 RVA Slack App - Production Environment Variables Configuration
# ==============================================================================
# These variables should be securely injected in production (e.g. via AWS SSM 
# Parameter Store) and never committed as plaintext.

# ------------------------------------------------------------------------------
# 1. Slack Application Configuration
# ------------------------------------------------------------------------------
# Obtained from your Slack App Console at https://api.slack.com/apps
# Requires 'users:read', 'users.profile:read', 'chat:write', and 'users:read.email' scopes.
SLACK_BOT_TOKEN=xoxb-your-production-bot-token

# ------------------------------------------------------------------------------
# 2. Slack Custom Profile Field IDs (Optional)
# ------------------------------------------------------------------------------
# Optional custom fields if your workspace supports them. 
# If left empty, the bot audits standard profile "What I do" (Title) descriptions.
EMERGENCY_CONTACT_PRIMARY_FIELD_ID=XF12345ABC
EMERGENCY_CONTACT_BACKUP_FIELD_ID=XF67890DEF

# ------------------------------------------------------------------------------
# 3. Email Notification Configuration (SES)
# ------------------------------------------------------------------------------
# The verified Amazon SES sender address (or verified domain address) that 
# compliance notification DMs/Emails will originate from.
EMAIL_SENDER_SOURCE=admin@f3rva.org

# ------------------------------------------------------------------------------
# 4. App Runtime Configuration
# ------------------------------------------------------------------------------
APP_ENV=production
