# ==============================================================================
# F3 RVA Slack App - Production Environment Variables Configuration
# ==============================================================================
# These variables should be securely injected in production (e.g. via AWS SSM 
# Parameter Store and AWS Secrets Manager) and never committed as plaintext.

# ------------------------------------------------------------------------------
# 1. Slack Application Configuration
# ------------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-production-bot-token
SLACK_SIGNING_SECRET=your-production-signing-secret

# ------------------------------------------------------------------------------
# 2. Slack Custom Profile Field IDs
# ------------------------------------------------------------------------------
START_DATE_FIELD_ID=Xf0XXXXXXXXX
EMERGENCY_CONTACT_PRIMARY_FIELD_ID=Xf0XXXXXXXXX
EMERGENCY_CONTACT_BACKUP_FIELD_ID=Xf0XXXXXXXXX

# ------------------------------------------------------------------------------
# 3. Google Sheets Backend Database Configuration
# ------------------------------------------------------------------------------
GOOGLE_SHEETS_SPREADSHEET_KEY=your-production-spreadsheet-key

# ------------------------------------------------------------------------------
# 4. Google Keyless Workload Identity Federation (WIF) Configuration (Strategy A)
# ------------------------------------------------------------------------------
# In production on AWS Lambda, pointing this variable to a federated credential 
# configuration file enables keyless authentication using the Lambda IAM Role.
# No service account JSON key is downloaded or stored in AWS.
GOOGLE_APPLICATION_CREDENTIALS=wif-credential-config.json

# ------------------------------------------------------------------------------
# 5. App Runtime Configuration
# ------------------------------------------------------------------------------
APP_ENV=production
