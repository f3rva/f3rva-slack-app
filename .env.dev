# ==============================================================================
# F3 RVA Slack App - Development Environment Variables Configuration
# ==============================================================================
# Copy these values into a local '.env' file for local execution or load them into 
# your local shell environment. 

# ------------------------------------------------------------------------------
# 1. Slack Application Configuration
# ------------------------------------------------------------------------------
# Obtained from your Slack App Console at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-development-bot-token
SLACK_SIGNING_SECRET=your-development-signing-secret

# ------------------------------------------------------------------------------
# 2. Slack Custom Profile Field IDs
# ------------------------------------------------------------------------------
# Create these custom fields in your Slack Workspace Admin Console, then retrieve 
# their field IDs to enable first-time fetch-and-seed lookup.
START_DATE_FIELD_ID=Xf0XXXXXXXXX
EMERGENCY_CONTACT_PRIMARY_FIELD_ID=Xf0XXXXXXXXX
EMERGENCY_CONTACT_BACKUP_FIELD_ID=Xf0XXXXXXXXX

# ------------------------------------------------------------------------------
# 3. Google Sheets Backend Database Configuration
# ------------------------------------------------------------------------------
# The unique key of the spreadsheet used as the database of record.
# Found in the Google Sheets URL: https://docs.google.com/spreadsheets/d/<KEY>/edit
GOOGLE_SHEETS_SPREADSHEET_KEY=your-development-spreadsheet-key

# ------------------------------------------------------------------------------
# 4. Google Keyless Developer Impersonation Settings (Strategy C)
# ------------------------------------------------------------------------------
# To bypass corporate Workspace OAuth blocks, the local app uses your standard 
# 'gcloud' identity (cloud-platform scope) and impersonates this Service Account 
# on the fly. No JSON key files are generated or downloaded.
GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=slack-app-local@YOUR_DEV_GCP_PROJECT_ID.iam.gserviceaccount.com

# ------------------------------------------------------------------------------
# 5. App Runtime Configuration
# ------------------------------------------------------------------------------
APP_ENV=development
PORT=3001
